{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ligate Labs",
  "description": "Developer documentation for Ligate, sovereign rollup, attestation protocol, and the three first-party flagship apps: Themisra (Proof of Prompt), Mneme (browser wallet), and Iris (MCP for AI agents).",
  "colors": {
    "primary": "#A7D28C",
    "light": "#A7D28C",
    "dark": "#8FBD70"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 600
    },
    "body": {
      "family": "Space Grotesk",
      "weight": 400
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://ligate.io"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "dark": "#0a0a0b",
      "light": "#f4f2ec"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": ["introduction", "quickstart", "devnet"]
          },
          {
            "group": "Protocol",
            "pages": ["chain", "proof-of-prompt", "tokenomics"]
          },
          {
            "group": "Developer surface",
            "pages": ["cli", "js", "sdks"]
          },
          {
            "group": "Reference",
            "pages": ["rpc", "api"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Explorer",
        "href": "https://explorer.ligate.io"
      },
      {
        "label": "ligate.io",
        "href": "https://ligate.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Join devnet",
      "href": "https://ligate.io/devnet"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/ligatelabs",
      "github": "https://github.com/ligate-io",
      "linkedin": "https://www.linkedin.com/company/ligate-labs"
    },
    "links": [
      {
        "header": "Resources",
        "items": [
          {
            "label": "Whitepaper",
            "href": "https://ligate.io/whitepaper"
          },
          {
            "label": "Roadmap",
            "href": "https://ligate.io/roadmap"
          },
          {
            "label": "Changelog",
            "href": "https://ligate.io/changelog"
          },
          {
            "label": "Blog",
            "href": "https://ligate.io/blog"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "Discord",
            "href": "https://discord.gg/ZWUeJ8k3eP"
          },
          {
            "label": "GitHub",
            "href": "https://github.com/ligate-io"
          },
          {
            "label": "Email",
            "href": "mailto:hello@ligate.io"
          }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search the Ligate docs"
  },
  "seo": {
    "metatags": {
      "og:site_name": "Ligate Labs Docs",
      "twitter:site": "@ligatelabs"
    },
    "indexing": "navigable"
  }
}
